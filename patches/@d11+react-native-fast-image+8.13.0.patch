+                  options:(JS::NativeFastImageViewModule::SpecGetOriginalSizeOptions &)options
+                  resolve:(RCTPromiseResolveBlock)resolve
+                  reject:(RCTPromiseRejectBlock)reject)
+{
+    NSURL *url = [NSURL URLWithString:source.uri()];
+    if (url == nil) {
+        reject(@"failure", @"Invalid URL", nil);
+        return;
+    }
+
+    SDWebImageManager *imageManager = [SDWebImageManager sharedManager];
+    NSString *key = [imageManager cacheKeyForURL:url];
+    UIImage *cachedImage = [[SDImageCache sharedImageCache] imageFromCacheForKey:key];
+    if (cachedImage) {
+        resolve(@{
